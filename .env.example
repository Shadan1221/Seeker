# Seeker environment template
# Copy values into the real env files used by each app:
# - server/.env (server runtime)
# - client/.env (local Vite dev)
# - client/.env.production (production frontend build)

# =========================
# Server environment values
# =========================
NODE_ENV=development
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,https://pathseeker.app
GROQ_API_KEY=your_groq_api_key_here

# =========================
# Client environment values
# =========================
VITE_API_URL=http://localhost:5000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# IMPORTANT:
# Never expose service role keys in frontend env files.
# Do NOT add VITE_SUPABASE_SERVICE_ROLE_KEY to client env.
